generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === 1. ПОЛЬЗОВАТЕЛИ И РОЛИ ===
model User {
  id                       String    @id @default(uuid())
  email                    String?   @unique
  phone                    String?   @unique 
  password                 String?
  name                     String?
  
  // === НОВЫЕ ПОЛЯ ДЛЯ TELEGRAM ===
  firstName                String?
  lastName                 String?
  username                 String?   @unique
  
  pavilion                 String?
  avatarUrl                String?
  role                     String    @default("USER")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  isOnboardingCompleted    Boolean   @default(false)

  globalSignature          String?   @default("")
  globalWatermark          GlobalWatermark?
  
  // === ПРИВЯЗКА СОЦСЕТЕЙ ===
  vkId                     String?   @unique
  telegramId               String?   @unique

  // === ПОДТВЕРЖДЕНИЕ ПОЧТЫ ===
  isEmailVerified          Boolean   @default(false)
  emailVerificationCode    String?
  emailVerificationExpires DateTime?
  
  // === БЕЗОПАСНОСТЬ ===
  resetPasswordToken       String?
  resetPasswordExpires     DateTime?
  
  accounts                 Account[] 
  sentRequests             Partnership[] @relation("SentRequests")
  receivedRequests         Partnership[] @relation("ReceivedRequests")
  notifications            Notification[]
  planId                   String?
  plan                     SubscriptionPlan? @relation(fields: [planId], references: [id])

  // === ШАРИНГ ПОСТОВ ===
  sentSharedPosts          SharedPost[] @relation("SentSharedPosts")
  receivedSharedPosts      SharedPost[] @relation("ReceivedSharedPosts")
}

// === 2. ТАРИФЫ (ПОДПИСКИ) ===
model SubscriptionPlan {
  id             String   @id @default(uuid())
  name           String   
  maxAccounts    Int    
  maxPostsPerDay Int    
  price          Int      @default(0)
  
  users          User[]
}

// === 3. ПОДКЛЮЧЕННЫЕ АККАУНТЫ (ГРУППЫ ВК/ТГ) ===
model Account {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String   
  providerId  String   
  accessToken String   
  name        String   
  avatarUrl   String?
  signature   String?  @default("")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isValid     Boolean  @default(true) 
  errorMsg    String?
  posts       Post[]
  watermark   Watermark? 
  
  @@unique([provider, providerId]) 
}

// === 4. ВОДЯНЫЕ ЗНАКИ ===
model Watermark {
  id            String   @id @default(uuid())
  accountId     String   @unique
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  type          String   @default("text")
  text          String?
  fontFamily    String?  @default("font-sans")
  visualStyle   String?  @default("glass")
  hasBackground Boolean  @default(true)
  imageUrl      String?
  position      String   @default("br")
  size          Int      @default(100)
  opacity       Int      @default(90)
  
  updatedAt     DateTime @updatedAt

  image         String?  @db.Text
  angle         Float    @default(0)
  textColor     String   @default("#FFFFFF")
  bgColor       String   @default("#000000")
  x             Float?
  y             Float?
}

// === 4.1 ГЛОБАЛЬНЫЙ ВОДЯНОЙ ЗНАК (ШАБЛОН) ===
model GlobalWatermark {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type          String   @default("text")
  text          String?
  image         String?  @db.Text
  angle         Float    @default(0)
  hasBackground Boolean  @default(true)
  textColor     String   @default("#FFFFFF")
  bgColor       String   @default("#000000")
  x             Float?
  y             Float?
  position      String   @default("br")
  size          Int      @default(100)
  opacity       Int      @default(90)
  
  updatedAt     DateTime @updatedAt
}

// === 5. ПОСТЫ И ПЛАНИРОВЩИК ===
model Post {
  id          String   @id @default(uuid())
  text        String?
  mediaUrls   String?  
  publishAt   DateTime? 
  status      String   @default("DRAFT") 
  accountId   String   
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

// === 6. ПАРТНЕРЫ ===
model Partnership {
  id          String   @id @default(uuid())
  requesterId String   
  receiverId  String   
  status      String   @default("PENDING") 
  createdAt   DateTime @default(now())

  requester   User     @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId]) 
}

// === 7. УВЕДОМЛЕНИЯ ===
model Notification {
  id        String   @id @default(uuid())
  userId    String   
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String   
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// === 8. ПОДЕЛИТЬСЯ С ПАРТНЕРАМИ ===
model SharedPost {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  text        String?
  mediaUrls   String?  @db.Text 
  createdAt   DateTime @default(now())

  sender      User     @relation("SentSharedPosts", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedSharedPosts", fields: [receiverId], references: [id], onDelete: Cascade)
}