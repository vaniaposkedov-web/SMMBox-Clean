generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Для продакшена поменяешь на postgresql
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  pavilion  String?  // НОВОЕ ПОЛЕ: Номер павильона
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  accounts  Account[] 
  watermark Watermark? 

  // НОВЫЕ СВЯЗИ ДЛЯ ПАРТНЕРОВ И УВЕДОМЛЕНИЙ
  sentRequests     Partnership[] @relation("SentRequests")
  receivedRequests Partnership[] @relation("ReceivedRequests")
  notifications    Notification[]
}

model Partnership {
  id          String   @id @default(uuid())
  requesterId String   // Кто отправил
  receiverId  String   // Кому отправили
  status      String   @default("PENDING") // PENDING (ожидает) или ACCEPTED (принята)
  createdAt   DateTime @default(now())

  requester   User     @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId]) // Защита от дублей заявок
}

// НОВАЯ ТАБЛИЦА: Уведомления
model Notification {
  id        String   @id @default(uuid())
  userId    String   
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String   // Текст уведомления
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Account {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String   // 'vk', 'telegram'
  providerId  String
  accessToken String
  name        String
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  posts       Post[]

  @@unique([provider, providerId]) 
}

model Post {
  id          String   @id @default(uuid())
  text        String?  
  mediaUrls   String?  
  publishAt   DateTime 
  status      String   @default("PENDING") 
  
  accountId   String   
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

// === НОВАЯ ТАБЛИЦА: Настройки водяного знака ===
model Watermark {
  id            String   @id @default(uuid())
  
  userId        String   @unique // Привязка к User
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type          String   @default("text") // 'text' или 'image'
  
  // Текстовые настройки
  text          String?
  fontFamily    String?  @default("font-sans")
  visualStyle   String?  @default("glass")
  hasBackground Boolean  @default(true)
  textColor     String?  @default("#FFFFFF")
  bgColor       String?  @default("#000000")
  
  // Настройки картинки (URL сохраненного файла)
  imageUrl      String?  
  
  // Общие настройки
  position      String   @default("br")
  size          Int      @default(100)
  opacity       Int      @default(90)
  angle         Int      @default(0)

  updatedAt     DateTime @updatedAt
}