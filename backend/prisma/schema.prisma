generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String    @id @default(uuid())
  email                    String?   @unique
  phone                    String?   @unique 
  password                 String?
  name                     String?
  
  firstName                String?
  lastName                 String?
  username                 String?   @unique
  
  pavilion                 String?
  avatarUrl                String?
  role                     String    @default("USER")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  isOnboardingCompleted    Boolean   @default(false)

  globalSignature          String?   @default("")
  globalWatermark          GlobalWatermark?
  
  vkId                     String?   @unique
  telegramId               String?   @unique

  isEmailVerified          Boolean   @default(false)
  emailVerificationCode    String?
  emailVerificationExpires DateTime?
  
  resetPasswordToken       String?
  resetPasswordExpires     DateTime?
  
  profiles                 SocialProfile[]
  accounts                 Account[]

  sentRequests             Partnership[] @relation("SentRequests")
  receivedRequests         Partnership[] @relation("ReceivedRequests")
  notifications            Notification[]
  
  planId                   String?
  plan                     SubscriptionPlan? @relation(fields: [planId], references: [id])

  sentSharedPosts          SharedPost[] @relation("SentSharedPosts")
  receivedSharedPosts      SharedPost[] @relation("ReceivedSharedPosts")

  isPro                    Boolean @default(false)
  proPlanType              String  @default("FREE") // FREE, BASIC, PRO
  proExpiresAt             DateTime?
  proExpiresAt             DateTime? 
  transactions             Transaction[] 
  systemLogs               SystemLog[]
}

model SocialProfile {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  provider          String    
  providerAccountId String    
  name              String?   
  avatarUrl         String?
  accessToken       String?   

  accounts          Account[] 

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([provider, providerAccountId]) 
}

model SubscriptionPlan {
  id             String   @id @default(uuid())
  name           String   
  maxAccounts    Int    
  maxPostsPerDay Int    
  price          Int      @default(0)
  users          User[]
}

model Account {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  profileId   String?  
  profile     SocialProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  provider    String   
  providerId  String   
  accessToken String  
  
  name        String   
  avatarUrl   String?
  signature   String?  @default("")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isValid     Boolean  @default(true) 
  errorMsg    String?
  posts       Post[]
  watermark   Watermark?
  
  @@unique([provider, providerId]) 
}

model Watermark {
  id            String   @id @default(uuid())
  accountId     String   @unique
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  type          String   @default("text")
  text          String?
  fontFamily    String?  @default("font-sans")
  visualStyle   String?  @default("glass")
  hasBackground Boolean  @default(true)
  imageUrl      String?
  position      String   @default("br")
  size          Int      @default(100)
  opacity       Int      @default(90)
  
  updatedAt     DateTime @updatedAt

  image         String?  @db.Text
  angle         Float    @default(0)
  textColor     String   @default("#FFFFFF")
  bgColor       String   @default("#000000")
  x             Float?
  y             Float?
}

model GlobalWatermark {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type          String   @default("text")
  text          String?
  image         String?  @db.Text
  angle         Float    @default(0)
  hasBackground Boolean  @default(true)
  textColor     String   @default("#FFFFFF")
  bgColor       String   @default("#000000")
  x             Float?
  y             Float?
  position      String   @default("br")
  size          Int      @default(100)
  opacity       Int      @default(90)
  
  updatedAt     DateTime @updatedAt
}

model Post {
  id          String   @id @default(uuid())
  text        String?
  mediaUrls   String?  
  publishAt   DateTime? 
  status      String   @default("DRAFT") 
  accountId   String   
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Partnership {
  id          String   @id @default(uuid())
  requesterId String   
  receiverId  String   
  status      String   @default("PENDING") 
  createdAt   DateTime @default(now())

  requester   User     @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId]) 
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  text      String   
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR, POST_SHARED
  metadata  String?  @db.Text         // JSON для хранения картинок и текста поста
  
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SharedPost {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  text        String?
  mediaUrls   String?  @db.Text 
  isPublished Boolean  @default(false) // Отслеживаем, опубликовал ли партнер пост
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender      User     @relation("SentSharedPosts", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedSharedPosts", fields: [receiverId], references: [id], onDelete: Cascade)
}

// === ФИНАНСЫ И ПЛАТЕЖИ ===
model Transaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount    Int      // Сумма в рублях
  type      String   @default("PRO_SUBSCRIPTION") 
  createdAt DateTime @default(now())
}

// === ГЛОБАЛЬНЫЕ НАСТРОЙКИ СИСТЕМЫ ===
model SystemSettings {
  id        String   @id @default("global") // Всегда одна запись
  aiPrompt  String   @db.Text               // Тот самый промпт для нейросети
  updatedAt DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(uuid())
  userId    String?  
  level     String   @default("ERROR") 
  module    String   
  message   String   
  details   String?  @db.Text 
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}