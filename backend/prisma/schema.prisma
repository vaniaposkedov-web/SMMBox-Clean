generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === 1. ПОЛЬЗОВАТЕЛИ И РОЛИ ===
model User {
  id                       String    @id @default(uuid())
  email                    String?   @unique // ИЗМЕНЕНО: теперь опционально
  phone                    String?   @unique 
  password                 String?           
  name                     String?
  
  // === НОВЫЕ ПОЛЯ ДЛЯ TELEGRAM ===
  firstName                String?
  lastName                 String?
  username                 String?   @unique // Никнейм в ТГ
  
  pavilion                 String?
  avatarUrl                String?
  role                     String    @default("USER")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  isOnboardingCompleted    Boolean   @default(false)
  isValid     Boolean  @default(true) // Работает ли аккаунт
  errorMsg    String?  // Текст ошибки (например: "Бот удален из канала")
  
  // === ПРИВЯЗКА СОЦСЕТЕЙ ===
  vkId                     String?   @unique
  telegramId               String?   @unique

  // === ПОДТВЕРЖДЕНИЕ ПОЧТЫ ===
  isEmailVerified          Boolean   @default(false)
  emailVerificationCode    String?
  emailVerificationExpires DateTime?
  
  // === БЕЗОПАСНОСТЬ ===
  resetPasswordToken       String?
  resetPasswordExpires     DateTime?
  
  accounts                 Account[] 
  sentRequests             Partnership[] @relation("SentRequests")
  receivedRequests         Partnership[] @relation("ReceivedRequests")
  notifications            Notification[]
  planId                   String?
  plan                     SubscriptionPlan? @relation(fields: [planId], references: [id])
}
// === 2. ТАРИФЫ (ПОДПИСКИ) ===
model SubscriptionPlan {
  id             String @id @default(uuid())
  name           String // "Базовый", "PRO"
  maxAccounts    Int    // Сколько групп можно привязать
  maxPostsPerDay Int    // Лимит постов в сутки
  price          Int    @default(0)
  
  users          User[]
}

// === 3. ПОДКЛЮЧЕННЫЕ АККАУНТЫ (ГРУППЫ ВК/ТГ) ===
model Account {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String   // 'vk', 'telegram', 'ok'
  providerId  String   // ID группы или канала
  accessToken String   // Токен для постинга
  name        String   // Название группы
  avatarUrl   String?

  signature   String?  @default("")  // <--- ДОБАВИТЬ ЭТУ СТРОКУ

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  posts       Post[]
  watermark   Watermark? // ВОДЯНОЙ ЗНАК ТЕПЕРЬ ПРИВЯЗАН СЮДА!

  @@unique([provider, providerId]) 
}

// === 4. ВОДЯНЫЕ ЗНАКИ (Индивидуально для каждого Аккаунта) ===
model Watermark {
  id            String   @id @default(uuid())
  
  accountId     String   @unique
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  type          String   @default("text")
  text          String?
  fontFamily    String?  @default("font-sans")
  visualStyle   String?  @default("glass")
  hasBackground Boolean  @default(true)
  imageUrl      String?  
  position      String   @default("br")
  size          Int      @default(100)
  opacity       Int      @default(90)
  

  updatedAt     DateTime @updatedAt

  image         String?  @db.Text
  angle         Float    @default(0)
  textColor     String   @default("#FFFFFF")
  bgColor       String   @default("#000000")
  x             Float?
  y             Float?
}

// === 5. ПОСТЫ И ПЛАНИРОВЩИК ===
model Post {
  id          String   @id @default(uuid())
  text        String?  
  mediaUrls   String?  
  
  publishAt   DateTime? // Время публикации (если null - публикуем сразу)
  status      String   @default("DRAFT") // DRAFT, SCHEDULED, PUBLISHED, FAILED
  
  accountId   String   
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

// === 6. ПАРТНЕРЫ ===
model Partnership {
  id          String   @id @default(uuid())
  requesterId String   
  receiverId  String   
  status      String   @default("PENDING") 
  createdAt   DateTime @default(now())

  requester   User     @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId]) 
}

// === 7. УВЕДОМЛЕНИЯ ===
model Notification {
  id        String   @id @default(uuid())
  userId    String   
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String   
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}